---
// Light/dark toggle. Persists choice to localStorage; works across View Transitions.
---

<button id="theme-toggle" type="button" aria-label="테마 전환" title="테마 전환">
  <svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
    <circle cx="12" cy="12" r="4.5" fill="currentColor" />
    <g stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="12" y1="2" x2="12" y2="4.5" />
      <line x1="12" y1="19.5" x2="12" y2="22" />
      <line x1="2" y1="12" x2="4.5" y2="12" />
      <line x1="19.5" y1="12" x2="22" y2="12" />
      <line x1="4.6" y1="4.6" x2="6.4" y2="6.4" />
      <line x1="17.6" y1="17.6" x2="19.4" y2="19.4" />
      <line x1="19.4" y1="4.6" x2="17.6" y2="6.4" />
      <line x1="6.4" y1="17.6" x2="4.6" y2="19.4" />
    </g>
  </svg>
  <svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
    <path
      d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"
      fill="currentColor"
    />
  </svg>
</button>

<style>
  #theme-toggle {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    padding: 0;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--card);
    color: var(--ink-700);
    cursor: pointer;
    transition: background-color var(--dur-fast) var(--ease-smooth),
      border-color var(--dur-fast) var(--ease-smooth),
      color var(--dur-fast) var(--ease-smooth);
  }
  #theme-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  #theme-toggle svg {
    grid-area: 1 / 1;
    transition: opacity var(--dur) var(--ease-smooth),
      transform var(--dur) var(--ease-smooth);
  }
  :root[data-theme='dark'] .icon-sun,
  :root:not([data-theme='dark']) .icon-moon {
    opacity: 0;
    transform: scale(0.6) rotate(-40deg);
  }
  :root[data-theme='dark'] .icon-moon,
  :root:not([data-theme='dark']) .icon-sun {
    opacity: 1;
    transform: scale(1) rotate(0);
  }
</style>

<script>
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>
