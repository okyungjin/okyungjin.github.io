---
import { getCollection } from 'astro:content';
import ListLayout from '../layouts/ListLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<ListLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="intro">
    <p class="intro__eyebrow">👋 안녕하세요</p>
    <h1 class="intro__title">DBA 정경진입니다</h1>
    <p class="intro__sub">데이터베이스를 다루며 배운 것들을 기록합니다.</p>
  </section>

  <div class="list-head">
    <h2>전체 글</h2>
    <span>{posts.length}개</span>
  </div>

  <div class="post-grid">
    {
      posts.map((post) => (
        <PostCard
          id={post.id}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          heroImage={post.data.heroImage}
        />
      ))
    }
  </div>
</ListLayout>

<style>
  .intro {
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line);
  }
  .intro__eyebrow {
    margin: 0 0 10px;
    color: var(--accent);
    font-weight: 700;
    font-size: 13.5px;
  }
  .intro__title {
    margin: 0 0 8px;
    font-size: clamp(22px, 3.5vw, 28px);
    line-height: 1.35;
  }
  .intro__sub {
    margin: 0;
    color: var(--ink-700);
    font-size: 15px;
  }
  .list-head {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 16px;
  }
  .list-head h2 {
    margin: 0;
    font-size: 17px;
  }
  .list-head span {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-500);
  }
</style>
