---
import { getCollection } from 'astro:content';
import ListLayout from '../../layouts/ListLayout.astro';
import { SITE_TITLE } from '../../consts';

const posts = await getCollection('posts');
const counts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    counts.set(tag, (counts.get(tag) ?? 0) + 1);
  }
}
const tags = [...counts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---

<ListLayout title="태그" description={`${SITE_TITLE}의 모든 태그`}>
  <div class="list-head fade-up">
    <h1>태그</h1>
    <span>{tags.length}개</span>
  </div>
  <div class="tag-cloud fade-up">
    {
      tags.map(([tag, count]) => (
        <a class="chip chip--lg" href={`/tags/${tag}/`}>
          #{tag}
          <span class="chip__count">{count}</span>
        </a>
      ))
    }
  </div>
</ListLayout>

<style>
  .list-head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 20px;
  }
  .list-head h1 {
    margin: 0;
    font-size: clamp(24px, 4vw, 30px);
  }
  .list-head span {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink-500);
  }
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .chip--lg {
    font-size: 14px;
    padding: 7px 13px;
  }
  .chip__count {
    color: var(--ink-500);
    font-weight: 700;
  }
</style>
