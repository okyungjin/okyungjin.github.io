---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Comments from '../components/Comments.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  headings?: Heading[];
}

const { title, description, pubDate, updatedDate, category, tags, headings = [] } =
  Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={title} description={description} type="article" />
  </head>
  <body>
    <Header />
    <TableOfContents headings={headings} />
    <main class="container container--narrow">
      <article class="post">
        <header class="post__header">
          <div class="post__tags">
            <a class="chip chip--cat" href={`/category/${encodeURIComponent(category)}/`}
              >{category}</a
            >
            {tags.map((t) => <a class="chip" href={`/tags/${t}/`}>#{t}</a>)}
          </div>
          <h1 class="post__title">{title}</h1>
          <p class="post__desc">{description}</p>
          <div class="post__meta">
            <FormattedDate date={pubDate} />
            {
              updatedDate && (
                <span class="post__updated">
                  · 업데이트 <FormattedDate date={updatedDate} />
                </span>
              )
            }
          </div>
        </header>
        <div class="prose">
          <slot />
        </div>
      </article>

      <Comments />

      <div class="post__back">
        <a href="/" class="back-link">← 목록으로</a>
      </div>
    </main>
    <Footer />

    <script>
      // Add a copy button to the top-right of every code block.
      const COPY_ICON =
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>';
      const CHECK_ICON =
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>';

      document.querySelectorAll<HTMLPreElement>('.prose pre').forEach((pre) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'copy-btn';
        btn.setAttribute('aria-label', '코드 복사');
        btn.innerHTML = COPY_ICON;
        let timer: ReturnType<typeof setTimeout> | undefined;

        async function copy(text: string) {
          try {
            await navigator.clipboard.writeText(text);
            return true;
          } catch {
            // Fallback for non-focused / insecure contexts.
            try {
              const ta = document.createElement('textarea');
              ta.value = text;
              ta.style.position = 'fixed';
              ta.style.opacity = '0';
              document.body.appendChild(ta);
              ta.select();
              const ok = document.execCommand('copy');
              document.body.removeChild(ta);
              return ok;
            } catch {
              return false;
            }
          }
        }

        btn.addEventListener('click', async () => {
          const code = (pre.querySelector('code')?.innerText ?? pre.innerText).replace(
            /\n+$/,
            '',
          );
          // Wrap in a fenced block so pasting elsewhere keeps the language.
          const lang = pre.getAttribute('data-language') || '';
          const payload = '```' + lang + '\n' + code + '\n```';
          if (!(await copy(payload))) return;
          btn.classList.add('is-copied');
          btn.innerHTML = CHECK_ICON;
          btn.setAttribute('aria-label', '복사됨');
          clearTimeout(timer);
          timer = setTimeout(() => {
            btn.classList.remove('is-copied');
            btn.innerHTML = COPY_ICON;
            btn.setAttribute('aria-label', '코드 복사');
          }, 1500);
        });

        pre.appendChild(btn);
      });
    </script>

    <style>
      .post {
        padding-top: 48px;
      }
      .post__header {
        margin-bottom: 40px;
        padding-bottom: 28px;
        border-bottom: 1px solid var(--line);
      }
      .post__tags {
        display: flex;
        gap: 7px;
        flex-wrap: wrap;
        margin-bottom: 18px;
      }
      .post__tags :global(.chip--cat) {
        color: var(--accent);
        background: var(--accent-weak);
        border-color: transparent;
      }
      .post__title {
        margin: 0 0 14px;
        font-size: clamp(28px, 5vw, 40px);
        line-height: 1.25;
      }
      .post__desc {
        margin: 0 0 18px;
        color: var(--ink-700);
        font-size: 17px;
        line-height: 1.6;
      }
      .post__meta {
        color: var(--ink-500);
        font-size: 14px;
      }
      .post__back {
        margin-top: 56px;
        padding-top: 24px;
        border-top: 1px solid var(--line);
      }
      .back-link {
        font-weight: 600;
        font-size: 15px;
        color: var(--ink-700);
      }
      .back-link:hover {
        color: var(--accent);
      }
    </style>

    <!-- Prose styles for markdown body (global so they reach rendered HTML). -->
    <style is:global>
      .prose {
        color: var(--ink-900);
        font-size: 16px;
        line-height: 1.66;
      }
      .prose > * + * {
        margin-top: 0.85em;
      }
      .prose :is(h2, h3, h4) {
        scroll-margin-top: 84px;
      }
      .prose h2 {
        margin-top: 1.8em;
        margin-bottom: 0.5em;
        font-size: 24px;
        font-weight: 800;
        padding-bottom: 0.3em;
        border-bottom: 1px solid var(--line);
      }
      /* h3: subsection, marked with a blue left accent bar. */
      .prose h3 {
        margin-top: 1.5em;
        margin-bottom: 0.4em;
        font-size: 19px;
        padding-left: 12px;
        border-left: 3px solid var(--accent);
      }
      /* h4: minor point, distinguished by size and weight only. */
      .prose h4 {
        margin-top: 1.2em;
        margin-bottom: 0.3em;
        font-size: 16.5px;
        color: var(--ink-900);
      }
      .prose p,
      .prose ul,
      .prose ol {
        color: var(--ink-700);
      }
      .prose strong {
        color: var(--ink-900);
        font-weight: 700;
      }
      .prose ul,
      .prose ol {
        padding-left: 1.4em;
      }
      .prose li {
        margin-top: 0.25em;
      }
      .prose li::marker {
        color: var(--ink-500);
      }
      .prose a {
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: color-mix(in srgb, var(--accent) 40%, transparent);
      }
      .prose hr {
        margin: 2.4em 0;
        border: 0;
        border-top: 1px solid var(--line);
      }
      .prose img {
        display: block;
        margin: 1.6em auto;
        border-radius: var(--radius-sm);
        border: 1px solid var(--line);
      }
      .prose blockquote {
        margin-inline: 0;
        padding: 4px 18px;
        border-left: 3px solid var(--accent);
        color: var(--ink-700);
        background: var(--accent-weak);
        border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
      }

      /* Inline code */
      .prose :not(pre) > code {
        font-family: var(--font-mono);
        font-size: 0.8em;
        padding: 1px 5px;
        border-radius: 6px;
        background: var(--surface);
        border: 1px solid var(--line);
        color: var(--ink-900);
        word-break: break-word;
      }

      /* Code blocks (Shiki) */
      .prose pre {
        position: relative;
        font-family: var(--font-mono);
        font-size: 12.5px;
        line-height: 1.5;
        padding: 16px 18px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--line);
        overflow-x: auto;
        tab-size: 2;
      }
      .prose pre > code {
        font-family: inherit;
      }

      /* Copy button (top-right of each code block) */
      .copy-btn {
        position: absolute;
        top: 9px;
        right: 9px;
        display: inline-grid;
        place-items: center;
        width: 28px;
        height: 28px;
        padding: 0;
        border: 0;
        border-radius: 7px;
        background: color-mix(in srgb, currentColor 9%, transparent);
        color: color-mix(in srgb, var(--ink-900) 55%, transparent);
        cursor: pointer;
        opacity: 0;
        transform: translateY(-1px);
        transition: opacity var(--dur-fast) var(--ease-smooth),
          background-color var(--dur-fast) var(--ease-smooth),
          color var(--dur-fast) var(--ease-smooth);
      }
      .prose pre:hover .copy-btn,
      .copy-btn:focus-visible {
        opacity: 1;
      }
      .copy-btn:hover {
        background: color-mix(in srgb, currentColor 16%, transparent);
        color: var(--ink-900);
      }
      .copy-btn.is-copied {
        opacity: 1;
        color: #2f9e44;
        background: color-mix(in srgb, #2f9e44 15%, transparent);
      }
      /* Always discoverable on touch devices (no hover). */
      @media (hover: none) {
        .copy-btn {
          opacity: 0.6;
        }
      }
      .copy-btn svg {
        width: 15px;
        height: 15px;
      }

      /* Shiki dual-theme: swap CSS vars on dark mode. */
      :root[data-theme='dark'] .prose .astro-code,
      :root[data-theme='dark'] .prose .astro-code span {
        color: var(--shiki-dark) !important;
        background-color: var(--shiki-dark-bg) !important;
        font-style: var(--shiki-dark-font-style) !important;
        font-weight: var(--shiki-dark-font-weight) !important;
        text-decoration: var(--shiki-dark-text-decoration) !important;
      }

      /* Tables */
      .prose table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14.5px;
        display: block;
        overflow-x: auto;
      }
      .prose th,
      .prose td {
        padding: 9px 14px;
        border: 1px solid var(--line);
        text-align: left;
      }
      .prose thead th {
        background: var(--surface);
        font-weight: 700;
        color: var(--ink-900);
      }
      .prose tbody tr:nth-child(even) {
        background: color-mix(in srgb, var(--surface) 50%, transparent);
      }
    </style>
  </body>
</html>
